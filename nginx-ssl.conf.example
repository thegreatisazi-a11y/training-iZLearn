# izLearn — nginx HTTPS / TLS configuration example (UR-163)
# Copy this file as your production nginx.conf to enable HTTPS.
#
# Prerequisites:
#   1. Obtain SSL certificates (Let's Encrypt via certbot, or org CA).
#   2. Place certificates at the paths shown below.
#   3. Replace "your-domain.com" with your actual domain.
#   4. Mount the certs directory as a Docker volume:
#        -v /etc/ssl/izlearn:/etc/ssl/izlearn:ro
#
# Usage:
#   In docker-compose.yml, override the nginx config:
#     volumes:
#       - ./nginx-ssl.conf.example:/etc/nginx/nginx.conf:ro
#       - /etc/ssl/izlearn:/etc/ssl/izlearn:ro
#   and expose port 443:
#     ports:
#       - "443:443"
#       - "80:80"   # for ACME challenge / redirect only

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;
    sendfile      on;
    gzip          on;

    # ── HTTP → HTTPS redirect ────────────────────────────────────────────
    server {
        listen 80;
        server_name your-domain.com;
        return 301 https://$host$request_uri;
    }

    # ── HTTPS server ─────────────────────────────────────────────────────
    server {
        listen 443 ssl http2;
        server_name your-domain.com;

        ssl_certificate     /etc/ssl/izlearn/fullchain.pem;
        ssl_certificate_key /etc/ssl/izlearn/privkey.pem;

        # Modern TLS settings (Mozilla Intermediate profile)
        ssl_protocols             TLSv1.2 TLSv1.3;
        ssl_ciphers               ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
        ssl_prefer_server_ciphers off;
        ssl_session_timeout       1d;
        ssl_session_cache         shared:SSL:10m;
        ssl_session_tickets       off;

        # HSTS (1 year, include subdomains)
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

        # Security headers
        add_header X-Frame-Options SAMEORIGIN always;
        add_header X-Content-Type-Options nosniff always;
        add_header Referrer-Policy strict-origin-when-cross-origin always;

        root /usr/share/nginx/html;
        index index.html;

        # ── API reverse proxy ────────────────────────────────────────────
        location /api/ {
            proxy_pass         http://backend:4000/api/;
            proxy_http_version 1.1;
            proxy_set_header   Host              $host;
            proxy_set_header   X-Real-IP         $remote_addr;
            proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto $scheme;
            proxy_read_timeout 120s;
            client_max_body_size 50m;
        }

        # ── SPA fallback ─────────────────────────────────────────────────
        location / {
            try_files $uri $uri/ /index.html;
        }
    }
}
