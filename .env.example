# ===========================================================================
# izLearn — root environment (used by docker-compose). Copy to .env and edit.
# ===========================================================================

# --- PostgreSQL ---
POSTGRES_USER=izlearn
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=izlearn

# --- Auth secrets (MUST be changed for production) ---
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# --- App ---
FRONTEND_ORIGIN=http://localhost:8080

# --- First SUPER_ADMIN seeded on initial migration ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_EMAIL=admin@example.com
