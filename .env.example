# ===========================================================================
# izLearn — root environment (used by docker-compose). Copy to .env and edit.
# ===========================================================================

# --- Database: MongoDB (Atlas or a self-hosted replica set) ---
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/izlearn?retryWrites=true&w=majority
# Self-hosted (must be a REPLICA SET — transactions require it):
#   mongodb://<user>:<pass>@<host>:27017/izlearn?replicaSet=rs0&authSource=admin
DATABASE_URL=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/izlearn?retryWrites=true&w=majority

# --- Auth secrets (MUST be changed for production) ---
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# --- App ---
# Public URL of the frontend (your Vercel deployment) — used for CORS.
FRONTEND_ORIGIN=https://your-app.vercel.app

# --- First SUPER_ADMIN seeded on initial start ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_EMAIL=admin@example.com
