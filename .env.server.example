# ===========================================================================
# izLearn — ON-PREMISES SERVER environment template.
#
# Copy this file to ".env" ON THE SERVER and fill in the real values:
#     cp .env.server.example .env
# Then start the stack:
#     docker compose -f docker-compose.server.yml up -d --build
#
# IMPORTANT: ".env" is git-ignored and must NEVER be committed. Keep a secure
# backup of this file separately (it is not in git).
# ===========================================================================

# --- Database -------------------------------------------------------------
# Self-hosted MongoDB runs as the "mongo" service (single-node replica set) on
# the internal Docker network. The default below already points at it, so you
# normally DO NOT need to set this. Override only if you use a different DB.
# DATABASE_URL=mongodb://mongo:27017/izlearn?replicaSet=rs0

# --- File storage ---------------------------------------------------------
# "local" stores uploaded materials/certificates/documents on a persistent
# Docker volume (recommended for a self-hosted server — no size cap, survives
# restarts). Leave as-is unless you intend to use Cloudflare R2.
STORAGE_DRIVER=local

# --- Auth secrets (REQUIRED — generate long random strings) ----------------
# Generate each one on the server with:  openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE-ME-long-random-string-1
JWT_REFRESH_SECRET=CHANGE-ME-long-random-string-2
# Token lifetimes (optional — sensible defaults applied if omitted).
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=8h
# BCRYPT_COST=12

# --- App URL (REQUIRED) ---------------------------------------------------
# The intranet address users will open in the browser. Use your domain name.
# HTTP for the initial pilot; switch to https:// when you enable TLS.
FRONTEND_ORIGIN=http://izlearn.yourco.local

# --- First SUPER_ADMIN (seeded once on first boot) ------------------------
# Change the password immediately after first login. The seed is idempotent and
# will NOT overwrite an existing admin.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_EMAIL=admin@yourco.local

# --- Cloudflare R2 (OPTIONAL — only if STORAGE_DRIVER is NOT "local") ------
# R2_BUCKET=izlearn
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_ENDPOINT=
