# ===========================================================================
# izLearn backend environment. Copy to backend/.env for local (non-Docker) dev.
# ===========================================================================

NODE_ENV=development
PORT=4000

# --- Database (PostgreSQL 15+ with pgcrypto; enabled by the init migration) ---
DATABASE_URL=postgresql://izlearn:izlearn@localhost:5432/izlearn?schema=public

# --- Redis (session store + Bull queues) ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# --- JWT (15-min access token, 8-hour refresh token) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=8h

# --- Password hashing ---
BCRYPT_COST=12

# --- CORS / frontend ---
FRONTEND_ORIGIN=http://localhost:5173

# --- File storage roots (created automatically on boot) ---
STORAGE_ROOT=./storage
STORAGE_MATERIALS=./storage/materials
STORAGE_DOCUMENTS=./storage/documents
STORAGE_CERTIFICATES=./storage/certificates
STORAGE_REPORTS=./storage/reports
STORAGE_TMP=./storage/tmp
BACKUP_DESTINATION=./storage/backups

# --- Backups & restore ---
PG_DUMP_BIN=pg_dump
PSQL_BIN=psql

# --- Puppeteer (set when using a system Chromium, e.g. in Docker) ---
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- Logging ---
LOG_LEVEL=info

# --- First SUPER_ADMIN (used by the seed) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_EMAIL=admin@example.com

# Note: LDAP, SMTP, backup schedule, password policy, reminder thresholds and
# org branding are stored in the SystemConfig table (editable in the UI under
# Master Setup → System Config), NOT here.
